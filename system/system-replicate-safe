#!/bin/sh
set -e

SRC=${1:-tank/data}
DST=${2:-tank/replica/data}

VERIFY_OUTPUT=$(system-replication-verify "$SRC" "$DST" 2>&1) || VERIFY_STATUS=$?
STATUS_LINE=$(echo "$VERIFY_OUTPUT" | grep '^STATUS=')
STATUS=${STATUS_LINE#STATUS=}

case "$STATUS" in
    OK)     ;;
    BEHIND) ;;
    EMPTY)  ;;
    DIVERGED)
        echo "$VERIFY_OUTPUT"
        exit 1
        ;;
    *)
        echo "ERROR: unknown verification state"
        echo "$VERIFY_OUTPUT"
        exit 1
        ;;
esac

system-replicate "$SRC" "$DST"

POST=$(system-replication-verify "$SRC" "$DST" 2>&1) || POST_STATUS=$?

POST_STATUS_LINE=$(echo "$POST" | grep '^STATUS=')
POST_STATE=${POST_STATUS_LINE#STATUS=}

if [ "$POST_STATE" != "OK" ]
then
    echo "$POST"
    echo "ERROR: replication did not converge"
    exit 1
fi

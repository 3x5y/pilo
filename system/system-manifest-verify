#!/bin/sh

PILE="/tank/data/active/pile"
MANIFEST="$PILE/.manifest"

STATUS=0

while read sum name; do
    file="$PILE/$name"
    [ -f "$file" ] || continue

    current=$(sha256sum "$file" | awk '{print $1}')

    if [ "$sum" != "$current" ]; then
        echo "[ERROR] mismatch: $name"
        STATUS=1
    fi
done < "$MANIFEST"

exit $STATUS

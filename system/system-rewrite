#!/bin/sh
set -e

PILE="$SYSTEM_ROOT/active/pile-readonly"

CMD="$1"

[ -n "$CMD" ] || {
    echo "ERROR: missing command"
    exit 1
}


exec_op() {
    mode="$1"   # validate | apply
    op="$2"
    src="$3"
    dst="$4"

    case "$op" in
        mv) ;;
        *)
            echo "ERROR: unsupported operation: '$op'"
            exit 1
            ;;
    esac

    case "$src" in
        /*|*..*)
            echo "ERROR: invalid source path"
            exit 1
            ;;
    esac

    case "$dst" in
        /*|*..*)
            echo "ERROR: invalid destination path"
            exit 1
            ;;
    esac

    SRC="/$PILE/$src"
    DST="/$PILE/$dst"

    [ -f "$SRC" ] || {
        echo "ERROR: source missing: $src"
        exit 1
    }

    if [ "$mode" = "validate" ]
    then
        if [ -f "$DST" ] && ! cmp -s "$SRC" "$DST"
        then
            echo "ERROR: destination conflict: $dst"
            exit 1
        fi
        return
    fi

    DIR=$(dirname "$DST")

    if [ -f "$DST" ]
    then
        rm "$SRC"
    else
        mkdir -p "$DIR"
        mv "$SRC" "$DST"
    fi
}

tmp=$(mktemp)
src_seen=$(mktemp)
dst_seen=$(mktemp)
printf "%s\n" "$CMD" > "$tmp"

TAB='	'

while IFS="$TAB" read -r op src dst extra
do
    [ -n "$op" ] || continue
    [ -z "$extra" ] || {
        echo "ERROR: invalid command (too many fields)"
        exit 1
    }
    [ -n "$src" ] && [ -n "$dst" ] || {
        echo "ERROR: invalid command: $op '$src' '$dst'"
        exit 1
    }
    if grep -Fxq "$src" "$src_seen"
    then
        echo "ERROR: duplicate source in script: $src"
        exit 1
    fi
    if grep -Fxq "$dst" "$dst_seen"
    then
        echo "ERROR: destination conflict in script: $dst"
        exit 1
    fi

    echo "$dst" >> "$dst_seen"
    echo "$src" >> "$src_seen"
    exec_op validate "$op" "$src" "$dst"
done < $tmp

rm -f "$src_seen"
rm -f "$dst_seen"

zfs set readonly=off $PILE
while IFS="$TAB" read -r op src dst extra
do
    [ -n "$op" ] || continue
    exec_op apply "$op" "$src" "$dst"
done < $tmp
zfs set readonly=on $PILE
rm -f "$tmp"
system-manifest-update

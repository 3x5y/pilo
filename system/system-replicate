#!/bin/sh
set -e

SRC="${1:-tank/data}"
DST="${2:-tank/replica/data}"

LAST_SRC=$(zfs list -t snapshot -o name -s creation | grep "^$SRC@" | tail -n1)
LAST_DST=$(zfs list -t snapshot -o name -s creation | grep "^$DST@" | tail -n1)

if [ -z "$LAST_SRC" ]
then
    echo "ERROR: no source snapshot"
    exit 1
fi

if [ -z "$LAST_DST" ]
then
    zfs send -R "$LAST_SRC" \
        | zfs receive -F "$DST"
else
    SNAP_NAME=$(echo "$LAST_SRC" | cut -d@ -f2)
    BASE_NAME=$(echo "$LAST_DST" | cut -d@ -f2)

    if [ "$SNAP_NAME" = "$BASE_NAME" ]
    then
        exit 0
    fi

    if ! zfs list -t snapshot "$SRC@$BASE_NAME" >/dev/null 2>&1
    then
        echo "ERROR: base snapshot missing on source: $SRC@$BASE_NAME"
        exit 1
    fi

    zfs send -R -i "$SRC@$BASE_NAME" "$LAST_SRC" \
        | zfs receive -F "$DST"
fi

#!/bin/sh
set -e

PILE="tank/data/active/pile-readonly"
STATIC="tank/data/static"
OUT="/$PILE/out"

[ -d "$OUT" ] || mkdir -p "$OUT"

# validate allowed top-level dirs
for d in "$OUT"/*
do
    [ -e "$d" ] || continue
    name=$(basename "$d")

    case "$name" in
        collection|filing) ;;
        *)
            echo "ERROR: invalid /out/ structure: $name"
            exit 1
            ;;
    esac
done

if [ -z "$(find "$OUT" -type f -print -quit)" ]
then
    echo "ERROR: /out/ directory empty"
    exit 1
fi


with_writable() {
    local dataset=$1
    shift
    zfs set readonly=off $dataset
    set +e
    "$@"
    local result=$?
    set -e
    zfs set readonly=on $dataset
    [ $result -eq 0 ] || exit $result
}


process_file() {
    local src="$1"
    local target="$2"
    local name=$(basename "$src")
    local dst="/$STATIC/$target/$name"
    local dataset="$STATIC/$target"

    if ! zfs list "$dataset" >/dev/null 2>&1; then
        echo "ERROR: dataset does not exist: $dataset"
        exit 1
    fi

    if [ -f "$dst" ]
    then
        if ! cmp -s "$src" "$dst"
        then
            echo "ERROR: destination conflict for $name"
            exit 1
        fi
    else
        with_writable $dataset \
            cp "$src" "$dst"
    fi

    with_writable $PILE \
        rm "$src"
}

COL_TMP=$(mktemp)
FIL_TMP=$(mktemp)
trap "rm -f '$COL_TMP' '$FIL_TMP'" EXIT

# collection
find "$OUT/collection" -type f > "$COL_TMP"
while IFS= read -r f
do
    process_file "$f" "collection"
done < "$COL_TMP"

# filing
find "$OUT/filing" -type f > "$FIL_TMP"
while IFS= read -r f
do
    rel=${f#$OUT/filing/}
    year=$(echo "$rel" | cut -d/ -f1)
    process_file "$f" "filing/$year"
done < "$FIL_TMP"

# update manifests
system-manifest-update
(
    cd "/$STATIC"
    tmp=$(mktemp)
    find . -type f ! -name .manifest -print0 \
      | LC_COLLATE=C sort -z \
      | xargs -r0 sha256sum > "$tmp"
    zfs set readonly=off $STATIC
    mv "$tmp" .manifest
    zfs set readonly=on $STATIC
)


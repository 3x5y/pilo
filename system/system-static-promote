#!/bin/sh
set -e

NAME="$1"
TARGET="$2"

PILE="tank/data/active/pile-readonly"
STATIC="tank/data/static"

[ -n "$NAME" ] && [ -n "$TARGET" ] || {
    echo "usage: system-file-item <filename> <destination>"
    exit 1
}

SRC="/$PILE/$NAME"
DST="/$STATIC/$TARGET"

case "$TARGET" in
    filing/*|collection)
        ;;
    *)
        echo "ERROR: invalid destination $TARGET"
        exit 1
        ;;
esac

[ -f "$SRC" ] || {
    echo "ERROR: source file missing"
    exit 1
}

DATASET="$STATIC/$TARGET"

if ! zfs list "$DATASET" >/dev/null 2>&1; then
    echo "ERROR: dataset does not exist: $DATASET"
    exit 1
fi

DST_FILE="$DST/$NAME"

with_writable() {
    local dataset=$1
    shift
    zfs set readonly=off $dataset
    set +e
    "$@"
    local result=$?
    set -e
    zfs set readonly=on $dataset
    [ $result -eq 0 ] || exit $result
}

if [ -f "$DST_FILE" ]
then
    if ! cmp -s "$SRC" "$DST/$NAME"
    then
        echo "ERROR: destination conflict for $NAME"
        exit 1
    else
        : # no-op: idempotent operation
    fi
else
    with_writable $DATASET \
        cp "$SRC" "$DST/"
fi

with_writable $PILE \
    rm "$SRC"

# update manifests
system-manifest-update
(
    cd "$DST"
    tmp=$(mktemp)
    find . -maxdepth 1 -type f ! -name .manifest -print0 \
      | LC_COLLATE=C sort -z \
      | xargs -r0 sha256sum > "$tmp"
    zfs set readonly=off $DATASET
    mv "$tmp" .manifest
    zfs set readonly=on $DATASET
)

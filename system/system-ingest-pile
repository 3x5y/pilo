#!/bin/sh
set -e

INTAKE=/tank/data/active/pile-intake
PILE=tank/data/active/pile-readonly
MANIFEST=/$PILE/.manifest

TMP_LIST=$(mktemp)
trap "rm -f '$TMP_LIST'" EXIT

find "$INTAKE" -type f | LC_COLLATE=C sort > "$TMP_LIST"

while IFS= read -r src
do
    rel=${src#$INTAKE/}
    dst="/$PILE/$rel"
    dst_dir=$(dirname "$dst")

    if [ -f "$dst" ]
    then
        if cmp -s "$src" "$dst"
        then
            rm "$src" # idempotent
        else
            echo "ERROR: name collision with different content: '$rel'"
            exit 1
        fi
    else
        zfs set readonly=off $PILE
        mkdir -p "$dst_dir"
        mv "$src" "$dst"
        zfs set readonly=on $PILE
    fi
done < "$TMP_LIST"

system-manifest-update

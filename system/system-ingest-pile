#!/bin/sh
set -e

INTAKE=/tank/data/active/pile-intake
PILE=tank/data/active/pile-readonly
MANIFEST=/$PILE/.manifest

for src in $INTAKE/*
do
    [ -f "$src" ] || continue

    name=$(basename "$src")
    dst="/$PILE/$name"

    if [ -f "$dst" ]
    then
        if cmp -s "$src" "$dst"
        then
            rm "$src" # idempotent
        else
            echo "ERROR: name collision with different content: '$name'"
            exit 1
        fi
    else
        zfs set readonly=off $PILE
        mv "$src" "$dst"
        zfs set readonly=on $PILE
    fi

done

# rebuild manifest from scratch
TMP=$(mktemp)
cd /$PILE

find . -maxdepth 1 -type f ! -name .manifest -print0 \
  | LC_COLLATE=C sort -z \
  | xargs -0 sha256sum > "$TMP"

zfs set readonly=off $PILE
mv "$TMP" "$MANIFEST"
zfs set readonly=on $PILE

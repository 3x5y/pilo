#!/bin/sh
set -e

INTAKE=/tank/data/active/pile-intake
PILE=tank/data/active/pile-readonly
MANIFEST=/$PILE/.manifest

for src in $INTAKE/*
do
    [ -f "$src" ] || continue

    name=$(basename "$src")
    dst="/$PILE/$name"

    if [ -f "$dst" ]
    then
        if cmp -s "$src" "$dst"
        then
            rm "$src" # idempotent
        else
            echo "ERROR: name collision with different content: '$name'"
            exit 1
        fi
    else
        zfs set readonly=off $PILE
        mv "$src" "$dst"
        zfs set readonly=on $PILE
    fi

done

# rebuild manifest from scratch
system-manifest-update

#!/bin/sh
set -e

INTAKE=$SYSTEM_ROOT/active/pile-intake
PILE=$SYSTEM_ROOT/active/pile-readonly

tmp_list=$(mktemp)
trap "rm -f '$tmp_list'" EXIT

find "/$INTAKE" -type f | LC_COLLATE=C sort > "$tmp_list"

while IFS= read -r src
do
    rel=${src#/$INTAKE/}
    dst="/$PILE/in/$rel"
    dst_dir=$(dirname "$dst")

    if [ -f "$dst" ]
    then
        if cmp -s "$src" "$dst"
        then
            rm "$src" # idempotent
        else
            echo "ERROR: name collision with different content: '$rel'"
            exit 1
        fi
    else
        zfs set readonly=off $PILE
        mkdir -p "$dst_dir"
        mv "$src" "$dst"
        zfs set readonly=on $PILE
    fi
done < "$tmp_list"

system-manifest-update

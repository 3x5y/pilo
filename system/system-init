#!/bin/sh
set -e

zfs create -p $SYSTEM_ROOT/active/pile-intake
zfs create -p $SYSTEM_ROOT/active/pile-readonly
zfs create -p $SYSTEM_ROOT/active/admin
zfs create -p $SYSTEM_ROOT/stash
zfs create -p $SYSTEM_ROOT/static/collection
zfs create -p $SYSTEM_ROOT/static/filing/2025

mkdir /$SYSTEM_ROOT/active/pile-readonly/in
mkdir /$SYSTEM_ROOT/active/pile-readonly/sort
mkdir /$SYSTEM_ROOT/active/pile-readonly/out
mkdir /$SYSTEM_ROOT/active/pile-readonly/out/collection
mkdir /$SYSTEM_ROOT/active/pile-readonly/out/filing

# protected areas
zfs set readonly=on $SYSTEM_ROOT/active/pile-readonly
zfs set readonly=on $SYSTEM_ROOT/static/collection
zfs set readonly=on $SYSTEM_ROOT/static/filing/2025

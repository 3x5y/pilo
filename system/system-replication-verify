#!/bin/sh
set -e

status_ok() {
    echo "STATUS=OK"
    exit 0
}

status_fail() {
    echo "STATUS=$1"
    echo "ERROR: $2"
    exit 1
}

latest_guid() {
    zfs list -t snap -s creation -Ho guid "$1" | tail -n1
}

SRC=${1:-tank/data}
DST=${2:-tank/replica/data}

SRC_GUID=$(latest_guid "$SRC")
DST_GUID=$(latest_guid "$DST")

if [ -z "$DST_GUID" ]
then
    echo "ERROR: no snapshots on target"
    exit 1
fi

SRC_GUIDS=$(mktemp)
DST_GUIDS=$(mktemp)

trap "rm $SRC_GUIDS $DST_GUIDS" EXIT

# iterate datasets on target
zfs list -r -t filesystem -Ho name "$DST" | while read -r dst_ds
do
    src_ds="tank/${dst_ds#tank/replica/}"
    zfs list -t snap -Ho guid "$src_ds" | sort > "$SRC_GUIDS"
    zfs list -t snap -Ho guid "$dst_ds" | sort > "$DST_GUIDS"

    if comm -23 "$DST_GUIDS" "$SRC_GUIDS" | grep -q .
    then
        echo "ERROR: replication divergence"
        exit 1
    fi

    src_latest=$(latest_guid "$src_ds")
    dst_latest=$(latest_guid "$dst_ds")

    if [ -n "$dst_latest" ] && [ "$src_latest" != "$dst_latest" ]
    then
        echo "ERROR: replication behind in $dst_ds"
        exit 1
    fi
done

zfs list -r -t filesystem -Ho name "$SRC" | while read -r src_ds
do
    dst_ds="tank/replica/${src_ds#tank/}"

    if ! zfs list "$dst_ds" >/dev/null 2>&1
    then
        echo "ERROR: replication behind (missing dataset $dst_ds)"
        exit 1
    fi
done

if [ "$SRC_GUID" != "$DST_GUID" ]
then
    echo "ERROR: replication behind"
    exit 1
fi

status_ok

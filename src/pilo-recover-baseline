#!/bin/sh
set -eu

HERE=$(dirname $(readlink -f "$0"))
. "$HERE"/lib.sh

require_arg "${1:-}" "replica dataset"
require_arg "${2:-}" "original dataset"
require_arg "${3:-}" "snapshot dataset"

SRC="$1"     # replica dataset (e.g. tank/replica/pile)
DST="$2"     # canonical dataset (e.g. tank/data/active/pile)
SNAP="$3"    # snapshot name (e.g. baseline)

SRC_SNAP="${SRC}@${SNAP}"

# --- validate source snapshot exists ---
if ! zfs list -t snapshot "$SRC_SNAP" >/dev/null 2>&1
then
    fatal "source snapshot does not exist: $SRC_SNAP"
fi

# --- ensure destination parent exists ---
DST_PARENT=$(echo "$DST" | sed 's|/[^/]*$||')
if [ -n "$DST_PARENT" ]
then
    zfs list "$DST_PARENT" >/dev/null 2>&1 || zfs create -p "$DST_PARENT"
fi

# --- destroy destination if it exists ---
if zfs list "$DST" >/dev/null 2>&1
then
    zfs destroy -r "$DST"
fi

# --- perform recovery ---
zfs send "$SRC_SNAP" | zfs receive "$DST"

# --- basic verification: snapshot now present on destination ---
if ! zfs list -t snapshot "${DST}@${SNAP}" >/dev/null 2>&1
then
    fatal "recovery completed but snapshot missing at destination"
fi

echo "Recovered $DST from $SRC_SNAP"
